# ── Institutional Intelligence Engine — Environment Template ─────────────────
# Instructions:
# 1. Copy this file to '.env' (cp .env.example .env)
# 2. Populate placeholders with actual institutional keys.
# 3. DO NOT COMMIT .env TO PUBLIC SOURCE CONTROL.

# ── Backend Configurations (Flask) ───────────────────────────────────────────
# Standard Flask Security Key (Required for session management)
FLASK_SECRET_KEY=quantum_dev_insecure_default_8829

# API Gateway Port (Default: 5000)
PORT=5000

# Simulation Mode (Set to true to use backend simulations without live brokers)
QUANT_ENGINE_SIMULATION_MODE=true

# ── Frontend Configurations (Vite) ──────────────────────────────────────────
# Base API URL (Must match the Backend Port)
VITE_API_URL=http://localhost:5000/api

# ── Third-Party Quantitative Providers ──────────────────────────────────────
# Alpaca / Interactive Brokers / TD Ameritrade (Optional)
ALPACA_API_KEY=YOUR_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_HERE

# AI Research Providers (OpenAI / Anthropic / Google)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ── Database & Cache ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://user:pass@localhost:5432/quant_db
