{
  "name": "professional-trading-terminal",
  "version": "2.0.0",
  "description": "Quantum Institutional Trading Terminal — Cross-Platform Edition",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev":              "vite",
    "build":            "vite build",
    "preview":          "vite preview",

    "pwa:build":        "vite build",

    "electron:dev":     "concurrently --kill-others \"cross-env BROWSER=none npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build":   "vite build && electron-builder --config electron-builder.json",

    "build:win":        "vite build && electron-builder --win --config electron-builder.json",
    "build:mac":        "vite build && electron-builder --mac --config electron-builder.json",
    "build:linux":      "vite build && electron-builder --linux --config electron-builder.json"
  },
  "dependencies": {
    "@ant-design/icons":    "^6.1.0",
    "@ant-design/plots":    "^2.6.8",
    "antd":                 "^6.3.4",
    "axios":                "^1.3.0",
    "d3":                   "^7.9.0",
    "d3-drag":              "^3.0.0",
    "d3-force":             "^3.0.0",
    "d3-scale":             "^4.0.2",
    "d3-selection":         "^3.0.0",
    "d3-shape":             "^3.2.0",
    "d3-transition":        "^3.0.1",
    "d3-zoom":              "^3.0.0",
    "date-fns":             "^2.29.3",
    "electron-is-dev":      "^2.0.0",
    "framer-motion":        "^10.0.1",
    "leaflet":              "^1.9.4",
    "lodash":               "^4.17.21",
    "react":                "^18.2.0",
    "react-dom":            "^18.2.0",
    "react-icons":          "^4.7.1",
    "react-is":             "^19.2.4",
    "react-leaflet":        "^4.2.1",
    "react-router-dom":     "^6.8.0",
    "recharts":             "^2.5.0",
    "socket.io-client":     "^4.6.0",
    "styled-components":    "^5.3.6",
    "vite-plugin-pwa":      "^0.16.4",
    "workbox-window":       "^7.0.0",
    "zustand":              "^5.0.12"
  },
  "devDependencies": {
    "@types/react":         "^18.0.27",
    "@types/react-dom":     "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "concurrently":         "^7.6.0",
    "cross-env":            "^7.0.3",
    "electron":             "^29.0.0",
    "electron-builder":     "^24.6.4",
    "vite":                 "^4.1.0",
    "wait-on":              "^7.0.1"
  }
}
